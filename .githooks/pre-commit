#!/bin/sh
# Defense-in-depth: block accidental commits of confidential tender data.
# Belt-and-braces alongside .gitignore.

staged=$(git diff --cached --name-only)

if printf '%s\n' "$staged" | grep -qE '(^|/)samples/|(^|/)drafts/|(^|/)reports/|(^|/)presentation/'; then
  echo "ERROR: confidential path detected in staged changes."
  echo "       samples/, drafts/, reports/, and presentation/ must not be committed."
  echo "       Unstage with: git restore --staged <path>"
  exit 1
fi

if printf '%s\n' "$staged" | grep -qE '\.(pptx|ppt|key)$|(^|/)~\$'; then
  echo "ERROR: Office deck or lockfile staged."
  echo "       Decks (.pptx/.ppt/.key) and ~\$* lockfiles must not be committed."
  exit 1
fi

if printf '%s\n' "$staged" | grep -qiE 'RFT.*\.docx|ITN.*\.(docx|pdf)|Selection Board Report|Assessment Notes|Tender Compliance Sheet|Procurement Report|Procurement Timelines|Tender Approval Form'; then
  echo "ERROR: a filename matching a known confidential NTA artefact is staged."
  echo "       Confirm the file is not real tender data before committing."
  exit 1
fi

exit 0
