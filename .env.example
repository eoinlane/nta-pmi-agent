# Copy to .env and fill in. .env is gitignored.

# Path to confidential sample tender data (local only — never committed)
SAMPLES_DIR=/path/to/your/samples

# Anthropic API
ANTHROPIC_API_KEY=

# TED API (public endpoint, no key required)
TED_API_BASE=https://ted.europa.eu/api/v3.0/notices

# Optional: web search grounding
BRAVE_API_KEY=

# Audit log location
AUDIT_DB_PATH=./audit.db
